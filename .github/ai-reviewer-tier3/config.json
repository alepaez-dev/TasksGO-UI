{
  "model": "claude-opus-4-8",
  "fallbackModel": "claude-opus-4-7",
  "maxTransientRetries": 0,
  "retryBaseDelayMs": 1000,
  "effort": "high",
  "maxOutputTokens": 64000,
  "taskBudgetTokens": 1200000,
  "costCeilingUsd": 2,
  "costWarnUsd": 1.5,
  "softWindDownFraction": 0.75,
  "logLevel": "info",
  "minConfidence": "medium",
  "minSeverity": "low",
  "maxFindings": 25,
  "allowUnchangedFileFindings": true,
  "maxFilePatchChars": 50000,
  "maxTotalDiffChars": 400000,
  "maxInputTokens": 1000000,
  "maxRounds": 40,
  "maxToolCalls": 120,
  "maxFileReadBytes": 200000,
  "maxGrepMatches": 400,
  "maxGrepFileBytes": 2000000,
  "toolExtensions": [".ts", ".tsx", ".js", ".jsx", ".css", ".json", ".md", ".mjs", ".cjs", ".yml", ".yaml"],
  "pricing": {
    "claude-opus-4-8": { "input": 5, "output": 25 },
    "claude-opus-4-7": { "input": 5, "output": 25 }
  },
  "includeProjectGuide": true,
  "postSummaryComment": true,
  "maxSummaryChars": 60000,
  "postRunStatusComment": true,
  "skipIfHeadUnchanged": true,
  "botActor": "github-actions[bot]",
  "markerPrefix": "ai-reviewer-tier3",
  "verifyResolutions": true,
  "resolveVerifiedFixes": true,
  "resolveOnlyForTrustedAuthors": true,
  "postResolutionReplies": true,
  "maxVerifyThreads": 20,
  "verifyWindowLines": 40,
  "maxVerifyFileChars": 60000,
  "maxVerifyOutputTokens": 24000,
  "ignore": [
    "**/package-lock.json",
    "**/*.lock",
    "**/*.snap",
    "**/*.svg",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.gif",
    "**/*.woff",
    "**/*.woff2",
    "**/dist/**",
    "**/build/**",
    "**/storybook-static/**",
    "**/node_modules/**",
    "**/*.min.js",
    "**/tokens.css",
    "**/typography.css",
    "**/CHANGELOG.md"
  ]
}
