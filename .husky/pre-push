branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ]; then
  exit 0
fi

pattern="^(feat|fix|chore|docs|refactor|test|ci|revert|hotfix)/.+"

if ! echo "$branch" | grep -qE "$pattern"; then
  echo ""
  echo "Branch name '$branch' is not allowed."
  echo "Use: <type>/<description>"
  echo "Types: feat fix chore docs refactor test ci revert hotfix"
  echo "Example: feat/icon-button"
  echo ""
  exit 1
fi
